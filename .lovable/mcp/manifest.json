{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://gwsjtbyqnwinykgtlmbv.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "agon-video-mcp",
      "version": "0.2.0",
      "title": "Agon Video Studio MCP"
    },
    "tools": [
      {
        "name": "analyze_video_prompt",
        "title": "Analyze video prompt",
        "description": "Analyze an Arabic or English video description and return a scene-by-scene shot plan (character, environment, camera moves, actions, narration) suitable for animated video production.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": false,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string",
              "minLength": 1,
              "description": "The video description to analyze."
            },
            "sceneCount": {
              "default": 4,
              "description": "Number of scenes to plan.",
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "type": {
              "default": "text-to-video",
              "description": "Kind of video generation.",
              "type": "string",
              "enum": [
                "text-to-video",
                "image-to-video"
              ]
            }
          },
          "required": [
            "prompt"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "build_scene_plan",
        "title": "Build executable scene plan",
        "description": "Convert the raw output of `analyze_video_prompt` into a normalized, execution-ready JSON scene plan (validated actions, cameras, per-scene durations, cumulative timing, and a full render manifest).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "analysis": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {},
              "description": "The structuredContent returned by analyze_video_prompt."
            },
            "fps": {
              "default": 30,
              "type": "integer",
              "minimum": 12,
              "maximum": 60
            },
            "secondsPerScene": {
              "default": 4,
              "type": "number",
              "minimum": 1,
              "maximum": 20
            }
          },
          "required": [
            "analysis"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "generate_scene_image",
        "title": "Generate scene image",
        "description": "Generate a single scene image via Lovable AI (Gemini image models). Returns a data URL for the produced image.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": false,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string",
              "minLength": 1,
              "description": "Image description."
            },
            "style": {
              "description": "Optional art style, e.g. 'cinematic', 'cartoon'.",
              "type": "string"
            }
          },
          "required": [
            "prompt"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
